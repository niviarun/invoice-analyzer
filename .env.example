# =============================================================
# Invoice Analyzer – Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit real credentials to version control.
# =============================================================

# AWS Account & Region
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-west-1

# S3 Bucket (used for raw uploads and processed output)
RAW_BUCKET=your-invoice-bucket
OUTPUT_BUCKET=your-invoice-bucket
OUTPUT_PREFIX=processed

# Step Function
STATE_MACHINE_ARN=arn:aws:states:us-west-1:123456789012:stateMachine:InvoiceAnalyzer

# Google Sheets Integration
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID

# AWS Secrets Manager – name of the secret holding Google service account JSON
SECRET_NAME=your-secret-name
