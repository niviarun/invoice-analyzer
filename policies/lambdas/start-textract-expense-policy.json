{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowTextractActions",
      "Effect": "Allow",
      "Action": [
        "textract:StartExpenseAnalysis",
        "textract:GetExpenseAnalysis"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowS3AccessForTextract",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::your-invoice-bucket",
        "arn:aws:s3:::your-invoice-bucket/*"
      ]
    },
    {
      "Sid": "Logging",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowKMSSync",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": "*"
    }
  ]
}
